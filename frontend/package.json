{
  "name": "don-os-frontend",
  "version": "0.1.1",
  "description": "Don OS Dashboard \u2014 SolidJS+Vite frontend for Hermes Agent",
  "private": true,
  "type": "module",
  "bin": {
    "don-os-frontend": "scripts/run.mjs"
  },
  "files": [
    "dist",
    "scripts/run.mjs"
  ],
  "engines": {
    "bun": ">=1.3.12"
  },
  "scripts": {
    "dev": "bunx vite --host",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "pm2": "vite build && vite preview --host 0.0.0.0 --port 3101"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "babylonjs": "^9.1.0",
    "dompurify": "^3.3.3",
    "marked": "^18.0.0",
    "monaco-editor": "^0.55.1",
    "shiki": "3.9.0",
    "solid-js": "^1.9.4"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "tailwindcss": "^4",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-solid": "^2.11.12"
  }
}
