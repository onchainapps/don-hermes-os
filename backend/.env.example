# ──────────────────────────────────────────────────────────
# Don Hermes OS — Profile .env Template
# ──────────────────────────────────────────────────────────
# This file is a reference. Each profile gets its own .env
# generated by the backend with auto-detected IP (hostname -I)
# and a unique API key + port.
#
# Copy this to ~/.hermes/profiles/<name>/.env and customize.

# ── API Server ────────────────────────────────────────────
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8650
API_SERVER_KEY=<generate a 64-char hex key: openssl rand -hex 32>
API_SERVER_CORS_ORIGINS=http://YOUR_LOCAL_IP:5173,http://localhost:5173,http://127.0.0.1:5173
API_SERVER_CORS_ALLOW_HEADERS=*
API_SERVER_CORS_ALLOWED_HEADERS=*
API_SERVER_CORS_EXPOSE_HEADERS=*

# ── LLM ────────────────────────────────────────────────────
LLM_MODEL=
DEFAULT_MODEL=
OPENAI_API_KEY=
VOICE_TOOLS_OPENAI_KEY=

# ── Terminal ──────────────────────────────────────────────
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300

# ── Browser ──────────────────────────────────────────────
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120

# ── Gateway ──────────────────────────────────────────────
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8642
GATEWAY_AUTH=

# ── Telegram ──────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# TELEGRAM_FREE_RESPONSE_CHATS=

# ── Other Integrations ──────────────────────────────────
# HF_TOKEN=
# FAL_KEY=
# TINKER_API_KEY=
# GLM_API_KEY=
# MINIMAX_API_KEY=
# PARALLEL_API_KEY=
# HONCHO_API_KEY=
# OLLAMA_API_KEY=
# HASS_URL=
# DISCORD_BOT_TOKEN=
# DISCORD_HOME_CHANNEL=
