{
  "name": "don-os-backend",
  "version": "0.1.1",
  "description": "Don OS Backend \u2014 Bun+Elysia API server with Hermes integration",
  "private": true,
  "type": "module",
  "bin": {
    "don-os-backend": "scripts/run.mjs"
  },
  "files": [
    "dist",
    "scripts/run.mjs",
    "src"
  ],
  "engines": {
    "bun": ">=1.3.12"
  },
  "scripts": {
    "build": "bun build server.ts --outdir=dist --target=bun",
    "start": "bun run server.ts",
    "dev": "bun run --watch server.ts",
    "test": "bun test",
    "pm2": "bun run dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2"
  }
}
